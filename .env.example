# Copy to .env and fill in values. This file is for LOCAL dev only.
# Vercel does NOT read .env — set the same vars in Vercel → Settings → Environment Variables.

# --- Local app database ---
# Leave commented → app uses data/leaderboard.db (safe default).
# Uncomment only if you intentionally want local dev to hit production Neon.
# DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# --- Leaderboard moderation ---
LEADERBOARD_BLOCKED_TERMS=word1,word2,word3

# --- Admin page (http://localhost:3000/admin, dev only) ---
# Generate with: openssl rand -hex 24
LEADERBOARD_ADMIN_KEY=replace-with-long-random-string
